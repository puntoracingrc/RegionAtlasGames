{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=6144",
      "NEXT_PUBLIC_SITE_URL": "https://regionatlas.games",
      "NEXT_PUBLIC_COVERS_BASE_URL": "https://www.puntoracing.net/MEDIAREGIONATLAS/covers"
    }
  },
  "crons": [
    {
      "path": "/api/cron/enrich-catalog-staging",
      "schedule": "0 4 * * *"
    }
  ],
  "functions": {
    "src/app/**/**": {
      "maxDuration": 60
    }
  }
}
