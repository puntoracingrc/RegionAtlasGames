{
  "name": "region-atlas-games",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=6144 next build",
    "start": "next start",
    "lint": "eslint",
    "sync:prices": "python3 scripts/sync_es_prices.py",
    "ingest:validate": "python3 scripts/build_ingest_template.py --validate data/price-ingest/pilot-dreamcast.json && python3 scripts/build_ingest_template.py --validate data/price-ingest/pilot-ps2.json && python3 scripts/build_ingest_template.py --validate data/price-ingest/pilot-ps4.json",
    "ingest:pilot": "bash scripts/run_pilot_sync.sh",
    "ingest:template": "python3 scripts/build_ingest_template.py",
    "ingest:import-csv": "python3 scripts/import_listings_csv.py",
    "ingest:ebay": "python3 scripts/collect_ebay_es.py",
    "ingest:jgo": "python3 scripts/collect_japangameonline.py",
    "ingest:chollo": "python3 scripts/collect_chollogames.py",
    "ingest:kaoto": "python3 scripts/collect_kaotostore.py",
    "ingest:cex": "python3 scripts/collect_cex.py",
    "ingest:wallapop": "python3 scripts/collect_wallapop.py",
    "ingest:vinted": "python3 scripts/collect_vinted.py",
    "ingest:todocoleccion": "python3 scripts/collect_todocoleccion.py",
    "ingest:todocoleccion:all": "python3 scripts/collect_todocoleccion.py --all",
    "ingest:todoconsolas": "python3 scripts/collect_todoconsolas.py",
    "ingest:todoconsolas:all": "python3 scripts/collect_todoconsolas.py --all",
    "ingest:daily": "python3 scripts/daily_price_ingest.py",
    "museum:details": "PYTHONUNBUFFERED=1 python3 scripts/seed_museum_details.py",
    "museum:indexes": "python3 scripts/seed_museum_details.py --indexes-only",
    "details:enrich": "PYTHONUNBUFFERED=1 python3 scripts/enrich_game_details.py",
    "details:wikidata": "PYTHONUNBUFFERED=1 python3 scripts/enrich_game_details.py --wikidata-only",
    "details:serialstation": "PYTHONUNBUFFERED=1 python3 scripts/enrich_serialstation.py",
    "details:indexes": "python3 scripts/enrich_game_details.py --indexes-only",
    "catalog:fix-pc-paths": "python3 scripts/fix_catalog_pc_paths.py",
    "descriptions:generate": "PYTHONUNBUFFERED=1 python3 scripts/generate_game_descriptions.py",
    "catalog:phase3": "bash scripts/run_phase3_catalog.sh",
    "covers:seed": "caffeinate -dimsu env PYTHONUNBUFFERED=1 python3 scripts/seed_covers.py",
    "covers:export-remote": "python3 scripts/export_cover_remote_urls.py",
    "storage:setup": "bash scripts/setup_external_storage.sh",
    "pipeline:watch": "caffeinate -dimsu bash scripts/watch_pipeline_progress.sh"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "country-flag-icons": "^1.6.17",
    "iron-session": "^8.0.4",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^4.8.0",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
