# =============================================================================
# Region Atlas — variables de entorno
# Copia a .env.local para desarrollo. En Vercel: Settings → Environment Variables
# =============================================================================

# --- Web (Vercel: Production + Preview recomendado) --------------------------
NEXT_PUBLIC_SITE_URL=https://regionatlas.games

# Sesión de login (Vercel Production obligatorio; Preview recomendado)
# Generar: openssl rand -base64 32
# SESSION_SECRET=

# --- Usuarios persistentes (Vercel) ------------------------------------------
# Conecta Storage → Blob al proyecto. Vercel añade BLOB_STORE_ID automáticamente.
# Para probar Blob en local, copia BLOB_READ_WRITE_TOKEN del dashboard de Vercel.
# BLOB_READ_WRITE_TOKEN=

# Alternativa solo local/servidor con disco (no usar en Vercel si hay Blob)
# APP_DATA_DIR=/ruta/escribible

# --- Email — enlace mágico (Vercel Production; Preview opcional) -------------
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Region Atlas <noreply@regionatlas.games>

# --- Assets públicos (opcional; vercel.json ya define portadas en build) -------
NEXT_PUBLIC_COVERS_BASE_URL=https://www.puntoracing.net/MEDIAREGIONATLAS/covers
# NEXT_PUBLIC_PLATFORMS_BASE_URL=https://www.puntoracing.net/MEDIAREGIONATLAS/platforms

# --- Ingest / scripts (solo .env.local o CI, no hace falta en Vercel web) ----
# OPENAI_API_KEY=
# EBAY_APP_ID=
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# REGION_VISION_DISABLED=1
# PAL_ES_RETRO_ROOT=/Volumes/Nuevo vol/pal-es-retro
# COVERS_ROOT=/Volumes/Nuevo vol/pal-es-retro/covers

# --- Login con Google (Vercel Production + Preview) --------------------------
# 1. Google Cloud Console → Credentials → OAuth client (Web)
# 2. Redirect URI autorizada:
#    https://regionatlas.games/api/auth/google/callback
#    http://localhost:3000/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
