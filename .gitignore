# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# auth (cuentas locales)
/data/users.json
/data/auth/
.env.local

# colecciones de usuario (importaciones Excel)
/data/collections/

# mercado entre usuarios
/data/marketplace/
/public/listing-photos/

# portadas en disco externo (symlink local — no subir a git/vercel)
/public/covers
public/covers

# datos pesados en disco externo (symlinks locales — ver npm run storage:setup)
/data/museum
/data/pc
/data/price-ingest
/data/wikidata
/data/serialstation
/data/descriptions
/data/covers

# informes locales de pipelines (regenerables)
/data/*-enrich-report.json
/data/ingest-recency.json

# logs de cron / scripts
/logs/

# ingest eBay (token + caché local — resto de price-ingest en disco externo)
/data/price-ingest/ebay-token-cache.json
/data/price-ingest/cache/
/data/price-ingest/reports/
